# ════════════════════════════════════════════
# A.E.G.I.S Server — Environment Variables
# Fill in your values before deploying to Render
# ════════════════════════════════════════════

# ── MongoDB ───────────────────────────────
# Paste your MongoDB Atlas connection string here
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/attendance?retryWrites=true&w=majority

# ── Security Keys ─────────────────────────
# Must match APP_SECRET_KEY in the mobile app's app.config.js
APP_SECRET_KEY=your_secret_key_here

# Optional: old key during APK transition
LEGACY_APP_SECRET=
LEGACY_SECRET_EXPIRES_AT=

# ── Admin Dashboard ───────────────────────
# TEST credentials (change before production)
ADMIN_USER=aegis_admin
ADMIN_PASSWORD=aegis@2025

# ── Email (Brevo) ─────────────────────────
BREVO_API_KEY=
EMAIL_FROM=work.anuragkishan@gmail.com
EMAIL_FROM_NAME=A.E.G.I.S Attendance

# ── Render ────────────────────────────────
# Set automatically by Render — leave blank locally
RENDER_EXTERNAL_URL=
PORT=3000
